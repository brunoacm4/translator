# ── Translator configuration ──────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# .env is gitignored — never commit real credentials or IPs.

# Slice Manager
SM_BASE_URL=http://localhost:8080       # Use real SM IP when VPN is active
SM_TIMEOUT=30.0                         # SM calls drive Selenium (~10-30s)
SM_HEALTH_TIMEOUT=5.0

# Logging
LOG_LEVEL=INFO                          # DEBUG for verbose local development
LOG_JSON=true                           # false for human-readable local output

# Circuit Breaker
CB_FAILURE_THRESHOLD=5                  # Open circuit after 5 consecutive failures
CB_RECOVERY_TIMEOUT=30.0               # Probe SM again after 30s

# Retry
RETRY_MAX_ATTEMPTS=2                    # 1 = no retry
RETRY_MIN_WAIT=0.5
RETRY_MAX_WAIT=3.0
